{
  "name": "welm-cdp",
  "version": "0.1.0",
  "description": "CDP tools",
  "type": "module",
  "bin": {
    "welm-cdp": "./cli.js"
  },
  "scripts": {
    "start": "node ./cli.js",
    "test": "node --test",
    "build:macos:dialog": "swiftc dialog/dialog.swift -o dialog/dialog.bin",
    "build:macos:file-clipboard": "swiftc clipboard/file-clipboard.swift -o clipboard/file-clipboard.bin",
    "build:macos:image-clipboard": "swiftc clipboard/image-clipboard.swift -o clipboard/image-clipboard.bin",
    "build:macos:clipboard": "npm run build:macos:file-clipboard && npm run build:macos:image-clipboard",
    "build:macos": "npm run build:macos:dialog && npm run build:macos:clipboard"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "chrome-remote-interface": "^0.34.0"
  },
  "exports": {
    "./common/assert": "./common/assert.js",
    "./common/config": "./common/config.js",
    "./common/log": "./common/log.js",

    "./cdp/chrome": "./cdp/chrome.js",
    "./cdp/client": "./cdp/client.js",
    "./cdp/runtime": "./cdp/runtime.js",
    "./cdp/dom": "./cdp/dom.js",
    "./cdp/input": "./cdp/input.js",
    "./cdp/mouse": "./cdp/mouse.js",
    "./cdp/screenshot": "./cdp/screenshot.js",

    "./cli/runner": "./cli/runner.js",

    "./web": "./web/index.js",

    "./fs": "./fs/index.js",
    "./clipboard": "./clipboard/index.js",
    "./dialog": "./dialog/dialog.js"
  }
}
