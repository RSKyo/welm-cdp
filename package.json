{
  "name": "welm-cdp",
  "version": "0.1.0",
  "description": "CDP tools",
  "type": "module",
  "bin": {
    "welm-cdp": "./cmd.js"
  },
  "scripts": {
    "start": "node ./cmd.js",
    "test": "node --test",
    "compile:file-clipboard": "swiftc clipboard/file-clipboard.swift -o clipboard/file-clipboard.bin",
    "compile:image-clipboard": "swiftc clipboard/image-clipboard.swift -o clipboard/image-clipboard.bin",
    "compile:clipboard": "npm run compile:file-clipboard && npm run compile:image-clipboard"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "chrome-remote-interface": "^0.34.0"
  },
  "exports": {
    "./chrome": "./cdp/chrome.js",
    "./client": "./cdp/client.js",
    "./dom": "./cdp/dom.js",
    "./input": "./cdp/input.js",
    "./mouse": "./cdp/mouse.js",
    "./screenshot": "./cdp/screenshot.js"
  }
}
